        "EXPO_PUBLIC_APP_SCHEME": "instride"
      }
    },
    "red-coat-farm": {
      "env": {
        "ORGANIZATION_SLUG": "red-coat-farm",
        "EXPO_PUBLIC_ORGANIZATION_SLUG": "red-coat-farm",
