{
  "extends": "@instride/config/tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "moduleResolution": "bundler",
    "module": "ES2022",
    "target": "ES2022",
    "declaration": true,
    "declarationMap": true,
    "composite": true,
    "strict": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "paths": {
      "#client": ["./src/client/index.ts"],
      "#_internal": ["./src/_internal/index.ts"],
      "#_internal/*": ["./src/_internal/*.ts"],
      "#modules/*": ["./src/modules/*.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
